SQL expression examples by transformation type:
  Date YYYYMMDD:
    TO_DATE(CAST({col} AS VARCHAR), 'YYYYMMDD')

  Date with sentinel:
    NULLIF(NULLIF(CAST({col} AS VARCHAR),'99999999'),'00000000')
    → then TO_DATE(result, 'YYYYMMDD')

  Scale div 100:
    ROUND(CAST({col} AS FLOAT) / 100.0, 6)

  Scale div 1000:
    ROUND(CAST({col} AS FLOAT) / 1000.0, 6)

  Magnitude mult 1000:
    CAST({col} AS FLOAT) * 1000.0

  Boolean:
    CASE WHEN UPPER(TRIM(CAST({col} AS VARCHAR)))
         IN ('Y','YES','TRUE','1','T') THEN TRUE
         WHEN UPPER(TRIM(CAST({col} AS VARCHAR)))
         IN ('N','NO','FALSE','0','F',' ','') THEN FALSE
         ELSE NULL END

  Sentinel nullification:
    NULLIF(NULLIF(NULLIF(TRIM({col}),'N/A'),'UNKN'),' ')

  FIPS to state alpha:
    DECODE(TRIM({col}),
      '01','AL','02','AK','04','AZ','05','AR','06','CA',
      '08','CO','09','CT','10','DE','11','DC','12','FL',
      '13','GA','15','HI','16','ID','17','IL','18','IN',
