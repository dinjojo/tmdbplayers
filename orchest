## PHASE 3: FIELD-LEVEL COMPARISON
================================================================================

Run only on MAPPED pairs with confidence HIGH or MEDIUM.
Apply all normalization BEFORE comparison. Never compare raw values.

### Step 3.1 — Universal Pre-Normalization

Apply these to every field before comparison:

  All strings:      TRIM(UPPER(CAST(value AS VARCHAR)))
  Sentinels:        NULLIF each discovered sentinel value → NULL
  Both NULL:        treat as MATCH
  CUSIP:            TRIM(UPPER(value)), assert LENGTH = 9
  DWR_NO (join):    LTRIM(TRIM(CAST(value AS VARCHAR)), '0')

  Booleans:
    TRUE  ← Y, YES, TRUE, 1, T
    FALSE ← N, NO, FALSE, 0, F, space, empty string

  Dates:
    Apply discovered format from Step 2.4 via TRY_TO_DATE()
    Sentinels '00000000', '99999999' → NULL
    2-digit year: if YY > 40 → 1900+YY, else → 2000+YY
    Julian YYDDD:
      DATEADD(day, SUBSTR(val,3,3)::INT - 1,
        TO_DATE(IFF(SUBSTR(val,1,2)::INT > 40,'19','20')
        || SUBSTR(val,1,2) || '0101','YYYYMMDD'))
    Julian YYYYDDD:
      DATEADD(day, SUBSTR(val,5,3)::INT - 1,
        TO_DATE(SUBSTR(val,1,4) || '0101','YYYYMMDD'))

  Rates:            ROUND(CAST(value AS FLOAT) * {scale_factor}, 6)
  Amounts:          CAST(value AS FLOAT) * {magnitude_factor}

### Step 3.2 — Rating Field Comparison

Ratings require decomposition. Never compare raw strings.

DECOMPOSE each rating value into components:

  run_sql("""
    SELECT
      raw_val,
      CASE WHEN raw_val LIKE '%*%' THEN TRUE ELSE FALSE END       AS on_watch,
      CASE WHEN raw_val LIKE '%/POS%' THEN 'POSITIVE'
           WHEN raw_val LIKE '%/NEG%' THEN 'NEGATIVE'
           WHEN raw_val LIKE '%/STA%' THEN 'STABLE'
           WHEN raw_val LIKE '%/DEV%' THEN 'DEVELOPING'
           ELSE NULL END                                           AS outlook,
      REGEXP_REPLACE(REGEXP_REPLACE(raw_val,'\\*[+-]?',''),'/[A-Z]+','')
                                                                   AS clean_rating,
      CASE
        WHEN REGEXP_LIKE(raw_val,'Aa[123]|Baa[123]|Ba[123]|Caa[123]|Aaa')
             THEN 'MOODYS'
        WHEN REGEXP_LIKE(raw_val,'AA[+-]?|BBB[+-]?|BB[+-]?|CCC[+-]?|AAA|^D$')
             THEN 'SP_FITCH'
        WHEN REGEXP_LIKE(raw_val,'^[0-9]{1,2}$')
             THEN 'NUMERIC_ORDINAL'
        WHEN raw_val IN ('NR','N/R','WR','WD','W','--','NA')
             THEN 'NOT_RATED'
        ELSE 'UNKNOWN'
      END                                                          AS notation_style,
      CASE WHEN REGEXP_LIKE(raw_val,'^[0-9]{1,2}$') THEN
        DECODE(raw_val::INT,
          1,'AAA', 2,'AA+',  3,'AA',   4,'AA-',  5,'A+',
          6,'A',   7,'A-',   8,'BBB+', 9,'BBB', 10,'BBB-',
         11,'BB+',12,'BB',  13,'BB-', 14,'B+',  15,'B',
         16,'B-', 17,'CCC+',18,'CCC', 19,'CCC-',20,'CC',
         21,'C',  'NR')
      END                                                          AS ordinal_to_sp
    FROM (SELECT '{VALUE}' AS raw_val)
  """)

COMPARISON STEPS:
  1. Normalize withdrawn: WR, WD, W, NR, N/R, NA, -- → NR
  2. Convert NUMERIC_ORDINAL → SP_FITCH via ordinal_to_sp
  3. Convert MOODYS → SP_FITCH equivalent for cross-notation comparison:
     Aaa→AAA  Aa1→AA+  Aa2→AA   Aa3→AA-
     A1→A+    A2→A     A3→A-
     Baa1→BBB+ Baa2→BBB Baa3→BBB-
     Ba1→BB+  Ba2→BB   Ba3→BB-
     B1→B+    B2→B     B3→B-
     Caa1→CCC+ Caa2→CCC Caa3→CCC-
     Ca→CC    C→C
  4. Compare same agency field against itself only
  5. Exact match after normalization → MATCH
  6. Strip modifier (+/-/1/2/3) and compare tier:
     Tier match, modifier differs → ENCODING_RATING_MODIFIER
  7. Tier differs → GENUINE_MISMATCH
  8. Moody's notation in SP field or vice versa → AGENCY_FIELD_SWAP (Tier 1)
  9. Watch/outlook differ only → RATING_QUALIFIER_DIFF (Tier 3)
  10. One side NR, other has rating → SENTINEL_VS_NULL (Tier 2)
  11. Mismatch crosses investment grade boundary (BBB-/Baa3) → Tier 1 regardless

### Step 3.3 — Per-Field Comparison Query

run_sql("""
  SELECT
    TRIM(UPPER(p.CUSIP))                               AS cusip,
    LTRIM(CAST(p.DWR_NO AS VARCHAR),'0')               AS dwr_no,
    '{CONCEPT_NAME}'                                   AS concept,
    '{PD_COLUMN}'                                      AS renovated_col,
    '{MSD_COLUMN}'                                     AS legacy_col,
    CAST(p.{PD_COLUMN} AS VARCHAR)                     AS raw_renovated,
    CAST(m.{MSD_COLUMN} AS VARCHAR)                    AS raw_legacy,
    {NORM_EXPR_PD}                                     AS norm_renovated,
    {NORM_EXPR_MSD}                                    AS norm_legacy,
    '{TRANSFORMATION}'                                 AS transformation_applied,
    CASE
      WHEN {NORM_EXPR_PD} IS NULL AND {NORM_EXPR_MSD} IS NULL  THEN 'MATCH_BOTH_NULL'
      WHEN {NORM_EXPR_PD} IS NULL AND {NORM_EXPR_MSD} IS NOT NULL THEN 'NULL_IN_RENOVATED'
      WHEN {NORM_EXPR_PD} IS NOT NULL AND {NORM_EXPR_MSD} IS NULL  THEN 'NULL_IN_LEGACY'
      WHEN {MATCH_CONDITION}                                        THEN 'MATCH'
      ELSE 'MISMATCH'
    END                                                AS comparison_result,
    ABS(TRY_TO_NUMBER({NORM_EXPR_PD})
      - TRY_TO_NUMBER({NORM_EXPR_MSD}))               AS numeric_diff,
    DATEDIFF('day',
      TRY_TO_DATE({NORM_EXPR_MSD}),
      TRY_TO_DATE({NORM_EXPR_PD}))                    AS date_diff_days
  FROM PRODUCT_DIM p
  JOIN MSD_CURRENT m
    ON TRIM(UPPER(p.CUSIP)) = TRIM(UPPER(m.{CUSIP_COL}))
   AND LTRIM(CAST(p.DWR_NO AS VARCHAR),'0') =
       LTRIM(CAST(m.DWR_NO AS VARCHAR),'0')
""")

MATCH_CONDITION by field type:
  String:   norm_renovated = norm_legacy
  Date:     date_diff_days = 0
  Rate:     ABS(norm_renovated::FLOAT - norm_legacy::FLOAT) < 0.000001
  Amount:   ABS(norm_renovated::FLOAT - norm_legacy::FLOAT)
              / NULLIF(ABS(norm_renovated::FLOAT), 0) < 0.001
  Boolean:  norm_renovated::BOOLEAN = norm_legacy::BOOLEAN
  Rating:   see Step 3.2

### Step 3.4 — Intra-Row Consistency Check

Before classifying cross-system mismatches, flag source-level inconsistencies
within each system. A record that is internally inconsistent in the source
should not count as a migration error.

run_sql("""
  SELECT 'MSD_CURRENT' AS src, {CUSIP_COL} AS cusip, DWR_NO,
         'CALLABLE_DATE_CONFLICT' AS issue
  FROM MSD_CURRENT
  WHERE {CALL_FLAG_COL} IN ('N','0','FALSE')
    AND {CALL_DATE_COL} NOT IN ('99999999','00000000',' ')
    AND {CALL_DATE_COL} IS NOT NULL

  UNION ALL

  SELECT 'MSD_CURRENT', {CUSIP_COL}, DWR_NO, 'MATURITY_IN_PAST'
  FROM MSD_CURRENT
  WHERE TRY_TO_DATE(CAST({MATURITY_COL} AS VARCHAR), '{DATE_FMT}') < CURRENT_DATE()
    AND TRY_TO_DATE(CAST({MATURITY_COL} AS VARCHAR), '{DATE_FMT}') IS NOT NULL

  UNION ALL

  SELECT 'MSD_CURRENT', {CUSIP_COL}, DWR_NO, 'ZERO_COUPON_RATE_CONFLICT'
  FROM MSD_CURRENT
  WHERE UPPER(TRIM({RATE_TYPE_COL})) IN ('Z','ZERO','ZC','ZERO_COUPON')
    AND CAST({COUPON_COL} AS FLOAT) > 0.001

  UNION ALL

  SELECT 'PRODUCT_DIM', CUSIP, CAST(DWR_NO AS VARCHAR), 'CALLABLE_DATE_CONFLICT'
  FROM PRODUCT_DIM
  WHERE IS_CALLABLE = FALSE AND FIRST_CALL_DATE IS NOT NULL

  UNION ALL

  SELECT 'PRODUCT_DIM', CUSIP, CAST(DWR_NO AS VARCHAR), 'REFUNDED_WITHOUT_ESCROW'
  FROM PRODUCT_DIM
  WHERE IS_REFUNDED = TRUE AND IS_ESCROWED = FALSE
""")

Flag all as SOURCE_DATA_INCONSISTENT. Reconcile separately from migration diffs.

### Step 3.5 — Coverage Gap Check

run_sql("""
  SELECT 'ONLY_IN_LEGACY' AS gap_type,
         TRIM(UPPER(m.{CUSIP_COL})) AS cusip,
         LTRIM(CAST(m.DWR_NO AS VARCHAR),'0') AS dwr_no
  FROM MSD_CURRENT m
  LEFT JOIN PRODUCT_DIM p
    ON TRIM(UPPER(p.CUSIP)) = TRIM(UPPER(m.{CUSIP_COL}))
   AND LTRIM(CAST(p.DWR_NO AS VARCHAR),'0') =
       LTRIM(CAST(m.DWR_NO AS VARCHAR),'0')
  WHERE p.CUSIP IS NULL

  UNION ALL

  SELECT 'ONLY_IN_RENOVATED',
         TRIM(UPPER(p.CUSIP)),
         LTRIM(CAST(p.DWR_NO AS VARCHAR),'0')
  FROM PRODUCT_DIM p
  LEFT JOIN MSD_CURRENT m
    ON TRIM(UPPER(p.CUSIP)) = TRIM(UPPER(m.{CUSIP_COL}))
   AND LTRIM(CAST(p.DWR_NO AS VARCHAR),'0') =
       LTRIM(CAST(m.DWR_NO AS VARCHAR),'0')
  WHERE m.{CUSIP_COL} IS NULL
""")

ONLY_IN_LEGACY = Tier 1 BLOCKING (missing migration records)
ONLY_IN_RENOVATED = NEW_ADDITION (not blocking)

